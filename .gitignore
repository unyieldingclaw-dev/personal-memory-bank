# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Local Claude Code permissions & secrets — never commit
.claude/settings.local.json

# Credential files — never commit
.env
.env.*
*.pem
*.key
id_rsa
id_ed25519
credentials.json

# Superpowers brainstorming sessions
.superpowers/

# Session handoff notes — ephemeral, consumed by next conversation then deleted
handoff.md

# Task contract files — session artifacts, never committed
.claude/contracts/*.json

# Local test files
test-project/
temp/

# Logs
*.log

# Office app lock files (PowerPoint, Word, Excel leave these when files are open)
~$*.pptx
~$*.docx
~$*.xlsx
